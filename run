#!/usr/bin/env sh
set -eu

if [ "$#" -lt 1 ]; then
  echo "用法: ./run lecture01" >&2
  exit 1
fi

lecture="$1"
dir="lectures/$lecture"

if [ ! -d "$dir" ]; then
  echo "未找到目录: $dir" >&2
  exit 1
fi

# 收集所有 .py 文件（排除 test_ 和 __pycache__）
files="$(find "$dir" -maxdepth 1 -type f -name '*.py' ! -name 'test_*' | sort)"

if [ -z "$files" ]; then
  echo "未找到可运行脚本。请在 $dir 下创建 Python 文件。" >&2
  exit 1
fi

count="$(echo "$files" | wc -l | tr -d ' ')"

if [ "$count" -eq 1 ]; then
  script="$files"
else
  echo "找到多个脚本，请选择:" >&2
  i=1
  echo "$files" | while IFS= read -r f; do
    echo "  $i) $(basename "$f")" >&2
    i=$((i + 1))
  done
  printf "输入编号 [1-%s]: " "$count" >&2
  read -r choice
  script="$(echo "$files" | sed -n "${choice}p")"
  if [ -z "$script" ] || [ ! -f "$script" ]; then
    echo "无效选择" >&2
    exit 1
  fi
fi

echo "运行: $script" >&2
exec uv run python "$script"
